---
interface Props {
  experiment: string;
  title: string;
  aspectRatio?: string;
}

const { experiment, title, aspectRatio = '4/3' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const src = `${base}/hsp/${experiment}/index.html`;
---

<div
  class="w-full rounded-lg overflow-hidden border border-boundary-blue/30 bg-black"
  style={`aspect-ratio: ${aspectRatio};`}
>
  <iframe
    src={src}
    class="w-full h-full border-0"
    allow="autoplay"
    title={title}></iframe>
</div>
