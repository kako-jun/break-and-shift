---
import '../styles/globals.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = '確率と割合の境界線 | Break and Shift',
  description = '確率と割合の境界線 - Borderline of Chance and Share',
  currentPath = '/',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+JP:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="min-h-screen bg-boundary-darker">
      <nav
        class="border-b border-boundary-blue/30 bg-boundary-darker/80 backdrop-blur-md sticky top-0 z-50"
      >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <a
              href={`${base}/`}
              class="text-xl font-serif text-boundary-silver hover:text-boundary-cyan transition-colors duration-300"
            >
              確率と割合の境界線
            </a>
          </div>
        </div>
      </nav>

      <div class="flex">
        <Sidebar currentPath={currentPath} />

        <main class="flex-1">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <slot />
          </div>
        </main>
      </div>

      <footer class="border-t border-boundary-blue/30 mt-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <p class="text-center text-boundary-mist text-sm">
            確率と割合の境界線 - Borderline of Chance and Share
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
